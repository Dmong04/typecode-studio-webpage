<header class="fixed top-0 left-0 w-full z-50">
  <section
    class="dark:bg-gray-900 bg-gray-100 p-4 flex justify-between md:justify-around items-center transition-colors duration-500 ease-in-out"
  >
    <h1 class="text-blue-200 font-bold text-3xl p-2 dark:text-blue-100">
      &reg;TypeCode Studio
    </h1>

    <!-- Nav desktop: visible solo en md+ -->
    <ul
      class="hidden md:flex dark:bg-gray-600 bg-blue-100 justify-center gap-10 rounded-full px-4 py-2 items-center transition-colors duration-500 ease-in-out"
    >
      <li>
        <a class="text-gray-400 hover:text-green-500 transition" href="#"
          >WhatsApp</a
        >
      </li>
      <li>
        <a class="text-gray-400 hover:text-orange-500 transition" href="#"
          >Email</a
        >
      </li>
      <li>
        <a class="text-gray-400 hover:text-blue-500 transition" href="#"
          >LinkedIn</a
        >
      </li>
      <li>
        <a class="text-gray-400 hover:text-cyan-500 transition" href="#"
          >GitHub</a
        >
      </li>
    </ul>

    <div class="flex items-center gap-3">
      <!-- Botón tema desktop -->
      <button
        id="theme-toggle-desktop"
        class="hidden md:flex items-center gap-2 bg-blue-100 dark:bg-gray-800 rounded-lg px-3 py-2 hover:bg-blue-200 dark:hover:bg-gray-700 transition"
      >
        <svg
          class="w-7 h-7 block dark:hidden text-blue-300"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M12 3v2m0 14v2m9-9h-2M5 12H3m15.364-6.364l-1.414 1.414M7.05 16.95l-1.414 1.414M16.95 16.95l1.414 1.414M7.05 7.05L5.636 5.636M12 7a5 5 0 100 10 5 5 0 000-10z"
          ></path>
        </svg>
        <svg
          class="w-7 h-7 hidden dark:block text-blue-300 fill-current"
          viewBox="0 0 20 20"
        >
          <path
            d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"
          ></path>
        </svg>
        <span class="text-gray-700 dark:text-gray-200">Change theme</span>
      </button>

      <!-- Botón hamburguesa: visible solo en móvil -->
      <button
        id="open-menu"
        class="md:hidden bg-gray-900 hover:bg-gray-800 text-white p-2 rounded-md aspect-square transition"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M4 6h16"></path><path d="M4 12h16"></path><path d="M4 18h16"
          ></path>
        </svg>
      </button>
    </div>
  </section>
</header>

<!-- Menú móvil overlay -->
<div
  id="mobile-menu"
  class="fixed top-0 left-0 h-full w-full z-50
         bg-gray-900/95 backdrop-blur-sm
         transition-transform duration-300 ease-in-out
         transform -translate-x-full
         md:hidden flex flex-col justify-center items-center gap-8 font-medium px-8"
>
  <a href="#" class="text-gray-400 hover:text-green-500 text-xl">WhatsApp</a>
  <a href="#" class="text-gray-400 hover:text-orange-500 text-xl">Email</a>
  <a href="#" class="text-gray-400 hover:text-blue-500 text-xl">LinkedIn</a>
  <a href="#" class="text-gray-400 hover:text-cyan-500 text-xl">GitHub</a>

  <!-- Botón tema móvil -->
  <button
    id="theme-toggle-mobile"
    class="flex items-center gap-2 bg-gray-800 rounded-lg px-3 py-2 text-gray-200"
  >
    <svg
      class="w-7 h-7 block dark:hidden text-blue-300"
      xmlns="http://www.w3.org/2000/svg"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M12 3v2m0 14v2m9-9h-2M5 12H3m15.364-6.364l-1.414 1.414M7.05 16.95l-1.414 1.414M16.95 16.95l1.414 1.414M7.05 7.05L5.636 5.636M12 7a5 5 0 100 10 5 5 0 000-10z"
      ></path>
    </svg>
    <svg
      class="w-7 h-7 hidden dark:block text-blue-300 fill-current"
      viewBox="0 0 20 20"
    >
      <path
        d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"
      ></path>
    </svg>
    <span class="text-gray-700 dark:text-gray-200">Change theme</span>
  </button>

  <!-- Botón cerrar -->
  <button
    id="close-menu"
    class="md:hidden bg-gray-900 hover:bg-gray-800 text-white p-2 rounded-md aspect-square transition"
  >
    ✕
  </button>
</div>
