<header class="fixed top-0 left-0 w-full z-50">
  <section
    class="dark:bg-gray-900 bg-gray-100 p-4 flex md:justify-around justify-between transition-colors duration-500 ease-in-out"
  >
    <h1
      class="text-center text-blue-200 font-bold text-3xl p-2 dark:text-blue-100"
    >
      &reg;TypeCode Studio
    </h1>

    <!-- Nav links — panel deslizante en móvil -->
    <div
      class="dark:bg-cyan-800 bg-blue-200 items-center flex gap-10 p-4 rounded-4xl"
    >
      <a
        class="text-gray-400 hover:text-green-500 transition-colors duration-300 ease-in-out"
        href="#">WhatsApp</a
      >
      <a
        class="text-gray-400 hover:text-orange-500 transition-colors duration-300 ease-in-out"
        href="#">Email</a
      >
      <a
        class="text-gray-400 hover:text-blue-500 transition-colors duration-300 ease-in-out"
        href="#">LinkedIn</a
      >
      <a
        class="text-gray-400 hover:text-cyan-500 transition-colors duration-300 ease-in-out"
        href="#">GitHub</a
      >

      <!-- Botón tema móvil -->
      <button
        id="theme-toggle-mobile"
        class="flex items-center gap-2 bg-gray-800 rounded-lg px-3 py-2 text-gray-200 md:hidden"
      >
        <svg
          class="w-6 h-6 block dark:hidden text-blue-300"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M12 3v2m0 14v2m9-9h-2M5 12H3m15.364-6.364l-1.414 1.414M7.05 16.95l-1.414 1.414M16.95 16.95l1.414 1.414M7.05 7.05L5.636 5.636M12 7a5 5 0 100 10 5 5 0 000-10z"
          ></path>
        </svg>
        <svg
          class="w-6 h-6 hidden dark:block text-blue-300 fill-current"
          viewBox="0 0 20 20"
        >
          <path
            d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"
          ></path>
        </svg>
        <span>Change theme</span>
      </button>

      <!-- Botón cerrar (X) -->
      <button
        id="close-menu"
        class="md:hidden bg-gray-800 hover:bg-gray-700 text-white p-2 rounded-md transition"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M18 6 6 18"></path>
          <path d="m6 6 12 12"></path>
        </svg>
      </button>
    </div>

    <div class="flex items-center gap-3">
      <!-- Botón tema desktop -->
      <button
        id="theme-toggle-desktop"
        class="hidden md:flex items-center gap-2 bg-blue-100 dark:bg-gray-800 rounded-lg px-3 py-2 hover:bg-blue-200 dark:hover:bg-gray-700 duration-300 transition-colors ease-in"
      >
        <svg
          class="w-7 h-7 block dark:hidden text-blue-300"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M12 3v2m0 14v2m9-9h-2M5 12H3m15.364-6.364l-1.414 1.414M7.05 16.95l-1.414 1.414M16.95 16.95l1.414 1.414M7.05 7.05L5.636 5.636M12 7a5 5 0 100 10 5 5 0 000-10z"
          ></path>
        </svg>
        <svg
          class="w-7 h-7 hidden dark:block text-blue-300 fill-current"
          viewBox="0 0 20 20"
        >
          <path
            d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"
          ></path>
        </svg>
        <span class="text-gray-700 dark:text-gray-200">Change theme</span>
      </button>

      <!-- Botón hamburguesa -->
      <button
        id="open-menu"
        class="menu-btn inline-block md:hidden active:scale-90 text-gray-700 dark:text-gray-200 bg-blue-200 dark:bg-gray-800 rounded-lg p-2 transition-colors duration-500 ease-in-out"
      >
        <svg
          class="w-7 h-7"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
  </section>
</header>
